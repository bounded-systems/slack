{
  "name": "@bounded-systems/slack",
  "version": "0.1.1",
  "description": "Policy-gated, provenance-tracked Slack read surface: bounded read ops behind a swappable transport port, with keymaker-minted scoped credentials",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/slack.git"
  },
  "homepage": "https://github.com/bounded-systems/slack#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/slack/issues"
  },
  "keywords": [
    "slack",
    "policy-gated",
    "provenance",
    "read-surface",
    "credentials"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bounded-systems/anchored-chain": "workspace:*",
    "@bounded-systems/anchored-chain-sqlite": "workspace:*",
    "@bounded-systems/auth": "workspace:*",
    "@bounded-systems/cas": "workspace:*",
    "@bounded-systems/env": "workspace:*",
    "@bounded-systems/policy": "workspace:*",
    "@bounded-systems/proc": "workspace:*"
  }
}
