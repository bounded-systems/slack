{
  "name": "@bounded-systems/slack",
  "version": "0.2.1",
  "description": "Policy-gated, provenance-tracked Slack read surface: bounded read ops behind a swappable transport port, with keymaker-minted scoped credentials",
  "bounded": {
    "tagline": "Policy-gated, provenance-tracked Slack read surface: bounded read ops behind a swappable transport port, with keymaker-minted scoped credentials",
    "kind": "door",
    "facet": "verb",
    "role": "reader",
    "domain": "slack/external"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/slack.git"
  },
  "homepage": "https://github.com/bounded-systems/slack#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/slack/issues"
  },
  "keywords": [
    "slack",
    "policy-gated",
    "provenance",
    "read-surface",
    "credentials"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@bounded-systems/anchored-chain": "npm:@jsr/bounded-systems__anchored-chain",
    "@bounded-systems/anchored-chain-sqlite": "npm:@jsr/bounded-systems__anchored-chain-sqlite",
    "@bounded-systems/cas": "npm:@jsr/bounded-systems__cas",
    "@bounded-systems/policy": "npm:@jsr/bounded-systems__policy"
  }
}
