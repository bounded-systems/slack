# slack.env.example — copy to `slack.env` (gitignored) and set YOUR vault.
#   cp packages/slack/slack.env.example packages/slack/slack.env
# 1Password references ONLY — no secrets. Resolved at runtime by
#   op run --env-file=packages/slack/slack.env -- <cmd>
# Replace VAULT with your vault name (must match OP_VAULT used by scripts/slack-setup.ts).
SLACK_CLIENT_ID=op://VAULT/slack-scout/client_id
SLACK_CLIENT_SECRET=op://VAULT/slack-scout/credential
SLACK_TOKEN=op://VAULT/slack-scout/token
